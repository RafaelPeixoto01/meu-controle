# backend/.env — copie para .env e preencha (CR-041)
# Em producao, configurar no Railway (nao usar .env). Referencia: CLAUDE.md "Variaveis de Ambiente"

# ===== Obrigatorias =====
# JWT — app nao inicia sem ela (CR-010). Gerar: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=troque-por-um-valor-aleatorio-longo
# Banco — se ausente, fallback para SQLite local (sqlite:///meu_controle.db)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ===== Google OAuth (CR-002) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/login

# ===== Email / SendGrid (CR-002) =====
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
FRONTEND_URL=http://localhost:5173

# ===== Analise IA (CR-032) =====
ANTHROPIC_API_KEY=
AI_ANALYSIS_ENABLED=false
CLAUDE_MODEL=claude-sonnet-4-20250514
AI_ANALYSIS_TIMEOUT_SECONDS=30

# ===== Auth/CORS (defaults razoaveis) =====
# ALLOWED_ORIGINS=http://localhost:5173
# ENVIRONMENT=development
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7
